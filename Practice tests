// Category sets
const SPEED_CATS = ['speed'];
const LIGHT_CATS = ['lights','signs'];

// ══════════════════════════════════════════════
//  STATE
// ══════════════════════════════════════════════
let selectedMode = 'full';
let examQuestions = [];
let currentIndex = 0;
let score = 0;
let wrongAnswers = [];
let timerInterval = null;
let timeLeft = 0;
let answered = false;

// ══════════════════════════════════════════════
//  MODE SELECTION
// ══════════════════════════════════════════════
function selectMode(el) {
  document.querySelectorAll('.mode-card').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  selectedMode = el.dataset.mode;
}

// ══════════════════════════════════════════════
//  START EXAM
// ══════════════════════════════════════════════
function startExam() {
  score = 0;
  currentIndex = 0;
  wrongAnswers = [];
  answered = false;

  let pool = [...ALL_QUESTIONS];

  if (selectedMode === 'speed') {
    pool = pool.filter(q => SPEED_CATS.includes(q.category));
  } else if (selectedMode === 'lights') {
    pool = pool.filter(q => LIGHT_CATS.includes(q.category));
  }

  // Shuffle
  pool = pool.sort(() => Math.random() - 0.5);

  const count = (selectedMode === 'quick') ? 10 : (selectedMode === 'full') ? 20 : Math.min(pool.length, 15);
  examQuestions = pool.slice(0, Math.min(count, pool.length));

  // Timer
  timeLeft = (selectedMode === 'quick') ? 10 * 60 : 20 * 60;

  showScreen('exam-screen');
  document.getElementById('q-total').textContent = examQuestions.length;
  document.getElementById('final-denom').textContent = `out of ${examQuestions.length}`;
  startTimer();
  renderQuestion();
}

// ══════════════════════════════════════════════
//  TIMER
// ══════════════════════════════════════════════
function startTimer() {
  clearInterval(timerInterval);
  updateTimerDisplay();
  timerInterval = setInterval(() => {
    timeLeft--;
    updateTimerDisplay();
    if (timeLeft <= 0) {
      clearInterval(timerInterval);
      showResults();
    }
  }, 1000);
}

function updateTimerDisplay() {
  const m = Math.floor(timeLeft / 60).toString().padStart(2,'0');
  const s = (timeLeft % 60).toString().padStart(2,'0');
  document.getElementById('timer-display').textContent = `${m}:${s}`;
  const badge = document.getElementById('timer-badge');
  badge.classList.toggle('urgent', timeLeft < 120);
}

// ══════════════════════════════════════════════
//  RENDER QUESTION
// ══════════════════════════════════════════════
function renderQuestion() {
  answered = false;
  const q = examQuestions[currentIndex];
  const total = examQuestions.length;

  document.getElementById('q-current').textContent = currentIndex + 1;
  document.getElementById('q-label').textContent = `Question ${currentIndex + 1}`;
  document.getElementById('q-text').textContent = q.q;
  document.getElementById('live-score').textContent = score;
  document.getElementById('progress-fill').style.width = `${(currentIndex / total) * 100}%`;

  const feedback = document.getElementById('feedback-box');
  feedback.className = 'feedback-box';
  feedback.textContent = '';

  const nextBtn = document.getElementById('btn-next');
  nextBtn.classList.remove('visible');
  nextBtn.textContent = currentIndex === total - 1 ? 'See Results →' : 'Next Question →';

  // Shuffle options with index tracking
  const labels = ['A','B','C','D'];
  const indices = [0,1,2,3].slice(0, q.opts.length);
  const shuffled = indices.sort(() => Math.random() - 0.5);

  const list = document.getElementById('options-list');
  list.innerHTML = '';
  shuffled.forEach((origIdx, i) => {
    const btn = document.createElement('button');
    btn.className = 'option-btn';
    btn.dataset.orig = origIdx;
    btn.innerHTML = `<span class="option-label">${labels[i]}</span><span>${q.opts[origIdx]}</span>`;
    btn.onclick = () => selectAnswer(btn, origIdx, q);
    list.appendChild(btn);
  });
}

// ══════════════════════════════════════════════
//  ANSWER SELECTION
// ══════════════════════════════════════════════
function selectAnswer(btn, origIdx, q) {
  if (answered) return;
  answered = true;

  const isCorrect = origIdx === q.correct;
  const feedback = document.getElementById('feedback-box');
  const allBtns = document.querySelectorAll('.option-btn');

  allBtns.forEach(b => {
    b.disabled = true;
    if (parseInt(b.dataset.orig) === q.correct) {
      b.classList.add('reveal-correct');
    }
  });

  if (isCorrect) {
    btn.classList.add('selected-correct');
    score++;
    document.getElementById('live-score').textContent = score;
    feedback.className = 'feedback-box correct';
    feedback.innerHTML = `<strong>✓ Correct!</strong> ${q.explain}`;
  } else {
    btn.classList.add('selected-wrong');
    feedback.className = 'feedback-box wrong';
    feedback.innerHTML = `<strong>✗ Incorrect.</strong> The correct answer was: <strong>${q.opts[q.correct]}</strong>. ${q.explain}`;
    wrongAnswers.push({ q: q.q, your: q.opts[origIdx], correct: q.opts[q.correct] });
  }

  document.getElementById('btn-next').classList.add('visible');
}

// ══════════════════════════════════════════════
//  NEXT QUESTION
// ══════════════════════════════════════════════
function nextQuestion() {
  currentIndex++;
  if (currentIndex >= examQuestions.length) {
    showResults();
  } else {
    renderQuestion();
  }
}

// ══════════════════════════════════════════════
//  RESULTS
// ══════════════════════════════════════════════
function showResults() {
  clearInterval(timerInterval);
  const total = examQuestions.length;
  const pct = Math.round((score / total) * 100);
  const passed = pct >= 80;

  document.getElementById('final-score').textContent = score;
  document.getElementById('final-denom').textContent = `out of ${total}`;

  const circle = document.getElementById('score-circle');
  circle.className = passed ? 'score-circle' : 'score-circle fail';

  document.getElementById('result-title').textContent =
    score === total ? '🏆 Perfect Score!' :
    pct >= 90 ? '🎯 Excellent!' :
    pct >= 80 ? '✅ Passed!' :
    '📚 Keep Studying';

  document.getElementById('result-sub').textContent =
    score === total ? 'Flawless. You are absolutely ready for the real exam.' :
    pct >= 90 ? `You got ${score}/${total}. You\'re well prepared — review your ${total-score} miss${total-score===1?'':'es'} and you\'re ready.` :
    pct >= 80 ? `You passed with ${pct}%. Review the questions you missed before the real exam.` :
    `You got ${score}/${total} (${pct}%). Focus on the topics you missed and try again.`;

  document.getElementById('stat-correct').textContent = score;
  document.getElementById('stat-wrong').textContent = total - score;
  document.getElementById('stat-pct').textContent = pct + '%';

  const reviewSection = document.getElementById('review-section');
  if (wrongAnswers.length > 0) {
    let html = `<h3>❌ Questions You Missed (${wrongAnswers.length})</h3>`;
    wrongAnswers.forEach(w => {
      html += `<div class="review-item">
        <div class="ri-q">${w.q}</div>
        <div class="ri-your">Your answer: ${w.your}</div>
        <div class="ri-correct">✓ Correct answer: ${w.correct}</div>
      </div>`;
    });
    reviewSection.innerHTML = html;
  } else {
    reviewSection.innerHTML = '<div style="text-align:center;color:var(--green);font-weight:600;font-size:15px;padding:20px">🎉 No mistakes — perfect round!</div>';
  }

  showScreen('results-screen');
}

// ══════════════════════════════════════════════
//  NAVIGATION
// ══════════════════════════════════════════════
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0, 0);
}

function restartSame() { startExam(); }
function goHome() {
  clearInterval(timerInterval);
  showScreen('start-screen');
}
