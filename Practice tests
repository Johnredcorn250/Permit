<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rwanda Driving Permit — Practice Exam</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap');

  :root {
    --green: #006C35;
    --green-light: #E8F5EC;
    --gold: #FAD02C;
    --dark: #1A1A1A;
    --light: #F7F5F0;
    --white: #FFFFFF;
    --red: #C0392B;
    --red-light: #FDECEA;
    --muted: #6B6B6B;
    --border: #E0DDD5;
    --radius: 10px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--light);
    color: var(--dark);
    min-height: 100vh;
  }

  /* ── SCREENS ── */
  .screen { display: none; }
  .screen.active { display: block; }

  /* ── START SCREEN ── */
  #start-screen {
    max-width: 580px;
    margin: 0 auto;
    padding: 48px 24px;
    text-align: center;
  }
  .logo-badge {
    display: inline-block;
    background: var(--green);
    color: var(--white);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }
  #start-screen h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 36px;
    line-height: 1.15;
    margin-bottom: 12px;
  }
  #start-screen p {
    color: var(--muted);
    font-size: 14px;
    margin-bottom: 36px;
    line-height: 1.7;
  }

  .mode-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-bottom: 28px;
  }
  .mode-card {
    background: var(--white);
    border: 2px solid var(--border);
    border-radius: var(--radius);
    padding: 20px 16px;
    cursor: pointer;
    transition: all 0.2s;
    text-align: left;
  }
  .mode-card:hover { border-color: var(--green); box-shadow: 0 4px 14px rgba(0,108,53,0.1); }
  .mode-card.selected { border-color: var(--green); background: var(--green-light); }
  .mode-card .icon { font-size: 26px; margin-bottom: 10px; }
  .mode-card h3 { font-size: 14px; font-weight: 600; margin-bottom: 4px; }
  .mode-card p { font-size: 12px; color: var(--muted); line-height: 1.5; }

  .btn-primary {
    display: inline-block;
    background: var(--green);
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    padding: 14px 36px;
    border-radius: 100px;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    width: 100%;
    max-width: 320px;
  }
  .btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }
  .btn-primary:active { transform: translateY(0); }

  .btn-secondary {
    display: inline-block;
    background: transparent;
    color: var(--green);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    padding: 10px 24px;
    border-radius: 100px;
    border: 2px solid var(--green);
    cursor: pointer;
    transition: all 0.2s;
    margin-top: 12px;
  }
  .btn-secondary:hover { background: var(--green-light); }

  /* ── EXAM SCREEN ── */
  #exam-screen { max-width: 680px; margin: 0 auto; padding: 24px 24px 80px; }

  .exam-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .exam-meta { font-size: 13px; color: var(--muted); }
  .exam-meta strong { color: var(--dark); }

  .timer-badge {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 6px 16px;
    font-size: 14px;
    font-weight: 600;
    color: var(--dark);
    display: flex;
    align-items: center;
    gap: 6px;
    transition: all 0.3s;
  }
  .timer-badge.urgent { background: #FFF0ED; border-color: var(--red); color: var(--red); }

  .progress-bar-wrap {
    background: var(--border);
    border-radius: 100px;
    height: 5px;
    margin-bottom: 28px;
    overflow: hidden;
  }
  .progress-bar-fill {
    height: 100%;
    background: var(--green);
    border-radius: 100px;
    transition: width 0.4s ease;
  }

  .question-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px 28px 24px;
    margin-bottom: 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
  .question-number {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green);
    margin-bottom: 10px;
  }
  .question-text {
    font-size: 16px;
    font-weight: 500;
    line-height: 1.55;
    margin-bottom: 22px;
  }

  .options-list { display: flex; flex-direction: column; gap: 10px; }
  .option-btn {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 13px 16px;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    background: var(--light);
    cursor: pointer;
    text-align: left;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: var(--dark);
    transition: all 0.15s;
    line-height: 1.45;
  }
  .option-btn:hover:not(:disabled) { border-color: var(--green); background: var(--green-light); }
  .option-btn:disabled { cursor: default; }
  .option-btn.selected-correct { border-color: var(--green); background: var(--green-light); color: #1E6B3C; }
  .option-btn.selected-wrong { border-color: var(--red); background: var(--red-light); color: var(--red); }
  .option-btn.reveal-correct { border-color: var(--green); background: var(--green-light); color: #1E6B3C; }

  .option-label {
    flex-shrink: 0;
    width: 24px; height: 24px;
    border-radius: 6px;
    background: var(--border);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px;
    font-weight: 700;
    color: var(--muted);
    margin-top: 0px;
  }
  .selected-correct .option-label { background: var(--green); color: var(--white); }
  .selected-wrong .option-label { background: var(--red); color: var(--white); }
  .reveal-correct .option-label { background: var(--green); color: var(--white); }

  .feedback-box {
    display: none;
    margin-top: 14px;
    padding: 14px 16px;
    border-radius: 8px;
    font-size: 13px;
    line-height: 1.65;
  }
  .feedback-box.correct { background: var(--green-light); border: 1px solid #A8D5B5; color: #1A5C30; display: block; }
  .feedback-box.wrong { background: var(--red-light); border: 1px solid #F1A899; color: #8B1A0F; display: block; }

  .next-btn-wrap { display: flex; justify-content: flex-end; margin-top: 16px; }
  .btn-next {
    background: var(--green);
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    padding: 11px 28px;
    border-radius: 100px;
    border: none;
    cursor: pointer;
    display: none;
    transition: opacity 0.2s;
  }
  .btn-next:hover { opacity: 0.85; }
  .btn-next.visible { display: block; }

  /* ── RESULTS SCREEN ── */
  #results-screen {
    max-width: 580px;
    margin: 0 auto;
    padding: 48px 24px;
    text-align: center;
  }
  .score-circle {
    width: 140px; height: 140px;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: 0 auto 28px;
    border: 6px solid var(--green);
    background: var(--green-light);
  }
  .score-circle.fail { border-color: var(--red); background: var(--red-light); }
  .score-circle .score-num {
    font-family: 'DM Serif Display', serif;
    font-size: 42px;
    color: var(--green);
    line-height: 1;
  }
  .score-circle.fail .score-num { color: var(--red); }
  .score-circle .score-denom { font-size: 13px; color: var(--muted); font-weight: 500; }

  #results-screen h2 {
    font-family: 'DM Serif Display', serif;
    font-size: 28px;
    margin-bottom: 10px;
  }
  #results-screen .result-sub { color: var(--muted); font-size: 14px; margin-bottom: 32px; line-height: 1.7; }

  .stats-row {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-bottom: 28px;
  }
  .stat-box {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 20px;
    min-width: 110px;
    flex: 1;
  }
  .stat-box .stat-val {
    font-family: 'DM Serif Display', serif;
    font-size: 28px;
    color: var(--dark);
  }
  .stat-box .stat-label { font-size: 12px; color: var(--muted); margin-top: 2px; }

  .review-section { text-align: left; margin-top: 36px; }
  .review-section h3 {
    font-size: 14px;
    font-weight: 600;
    color: var(--red);
    margin-bottom: 14px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }
  .review-item {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
    margin-bottom: 10px;
    font-size: 13px;
  }
  .review-item .ri-q { font-weight: 500; margin-bottom: 6px; line-height: 1.5; }
  .review-item .ri-your { color: var(--red); font-size: 12px; }
  .review-item .ri-correct { color: var(--green); font-size: 12px; font-weight: 600; }

  .result-actions { display: flex; flex-direction: column; align-items: center; gap: 10px; margin-top: 32px; }

  @media (max-width: 500px) {
    .mode-grid { grid-template-columns: 1fr; }
    .stats-row { flex-wrap: wrap; }
    #start-screen h1 { font-size: 28px; }
  }
</style>
</head>
<body>

<!-- ══════════════════════════════════
     START SCREEN
════════════════════════════════════ -->
<div id="start-screen" class="screen active">
  <div class="logo-badge">Rwanda Road Code</div>
  <h1>Driving Permit<br>Practice Exam</h1>
  <p>Simulate the real permit test. Get instant feedback on every question. Track your weak areas and improve.</p>

  <div class="mode-grid">
    <div class="mode-card selected" data-mode="full" onclick="selectMode(this)">
      <div class="icon">📋</div>
      <h3>Full Exam (20 Q)</h3>
      <p>Timed. Mirrors the real permit test. Target: 20/20.</p>
    </div>
    <div class="mode-card" data-mode="quick" onclick="selectMode(this)">
      <div class="icon">⚡</div>
      <h3>Quick Practice (10 Q)</h3>
      <p>Shorter session. Great for a fast review.</p>
    </div>
    <div class="mode-card" data-mode="speed" onclick="selectMode(this)">
      <div class="icon">🎯</div>
      <h3>Speed Limits Only</h3>
      <p>Drill only speed & distance questions.</p>
    </div>
    <div class="mode-card" data-mode="lights" onclick="selectMode(this)">
      <div class="icon">💡</div>
      <h3>Lights & Signs Only</h3>
      <p>Drill lights, reflectors, and road sign colors.</p>
    </div>
  </div>

  <button class="btn-primary" onclick="startExam()">Start Exam →</button>
  <br>
  <small style="color:var(--muted);font-size:12px;display:block;margin-top:16px;">Questions are randomized each session</small>
</div>

<!-- ══════════════════════════════════
     EXAM SCREEN
════════════════════════════════════ -->
<div id="exam-screen" class="screen">
  <div class="exam-header">
    <div class="exam-meta">Question <strong id="q-current">1</strong> of <strong id="q-total">20</strong></div>
    <div class="timer-badge" id="timer-badge">⏱ <span id="timer-display">20:00</span></div>
    <div class="exam-meta">Score: <strong id="live-score">0</strong></div>
  </div>

  <div class="progress-bar-wrap">
    <div class="progress-bar-fill" id="progress-fill" style="width:0%"></div>
  </div>

  <div class="question-card">
    <div class="question-number" id="q-label">Question 1</div>
    <div class="question-text" id="q-text">Loading...</div>
    <div class="options-list" id="options-list"></div>
    <div class="feedback-box" id="feedback-box"></div>
  </div>

  <div class="next-btn-wrap">
    <button class="btn-next" id="btn-next" onclick="nextQuestion()">Next Question →</button>
  </div>
</div>

<!-- ══════════════════════════════════
     RESULTS SCREEN
════════════════════════════════════ -->
<div id="results-screen" class="screen">
  <div class="score-circle" id="score-circle">
    <div class="score-num" id="final-score">0</div>
    <div class="score-denom" id="final-denom">out of 20</div>
  </div>
  <h2 id="result-title">Well done!</h2>
  <p class="result-sub" id="result-sub">Keep it up.</p>

  <div class="stats-row">
    <div class="stat-box">
      <div class="stat-val" id="stat-correct">0</div>
      <div class="stat-label">✅ Correct</div>
    </div>
    <div class="stat-box">
      <div class="stat-val" id="stat-wrong">0</div>
      <div class="stat-label">❌ Wrong</div>
    </div>
    <div class="stat-box">
      <div class="stat-val" id="stat-pct">0%</div>
      <div class="stat-label">📊 Score</div>
    </div>
  </div>

  <div class="review-section" id="review-section"></div>

  <div class="result-actions">
    <button class="btn-primary" onclick="restartSame()">Try Again (Same Mode)</button>
    <button class="btn-secondary" onclick="goHome()">← Change Mode</button>
  </div>
</div>

<script>
// ══════════════════════════════════════════════
//  QUESTION BANK
// ══════════════════════════════════════════════
const ALL_QUESTIONS = [
  {
    id:1, category:'general',
    q:"Every vehicle or set of vehicles in motion must have:",
    opts:["A driver only","A conveyor only","Both a driver and a conveyor","No correct answer"],
    correct:2,
    explain:"Every vehicle in motion requires both a driver AND a conveyor (escort/attendant)."
  },
  {
    id:2, category:'general',
    q:"The term 'Foot path' designates a narrow public way accessible only to traffic of:",
    opts:["Pedestrians","Two-wheel vehicles","Pedestrians and two-wheel vehicles","All vehicles"],
    correct:0,
    explain:"A footpath is exclusively for pedestrians."
  },
  {
    id:3, category:'speed',
    q:"Out of agglomeration, the maximum speed of a moped (cyclomoteur) is:",
    opts:["30 km/h","40 km/h","50 km/h","60 km/h"],
    correct:2,
    explain:"Outside built-up areas, mopeds are limited to 50 km/h."
  },
  {
    id:4, category:'speed',
    q:"Without specific restrictive regulations, the maximum speed of motorcycles is:",
    opts:["25 km/h","70 km/h","40 km/h","60 km/h"],
    correct:2,
    explain:"In the absence of more restrictive rules, the default motorcycle speed limit is 40 km/h."
  },
  {
    id:5, category:'speed',
    q:"Without specific regulations, the maximum speed for passenger service vehicles is:",
    opts:["40 km/h","60 km/h","75 km/h","20 km/h"],
    correct:1,
    explain:"Default maximum for public transport (passenger service) vehicles is 60 km/h."
  },
  {
    id:6, category:'speed',
    q:"Without specific regulations, the maximum speed for taxis/hackney carriages (authorized weight ≤3,500 kg) is:",
    opts:["60 km/h","40 km/h","75 km/h","20 km/h"],
    correct:2,
    explain:"Taxis and hackney carriages weighing up to 3,500 kg have a default maximum of 75 km/h."
  },
  {
    id:7, category:'speed',
    q:"When passing a pedestrian near an obstacle, if a 1m free space cannot be left, the maximum speed allowed is:",
    opts:["10 km/h","20 km/h","30 km/h","No speed limit"],
    correct:1,
    explain:"If a 1m free space cannot be left beside an obstacle, you must pass the pedestrian at no more than 20 km/h."
  },
  {
    id:8, category:'speed',
    q:"Vehicles must be fitted with a speedometer if likely to exceed on flat surface:",
    opts:["60 km/h","40 km/h","30 km/h","25 km/h"],
    correct:1,
    explain:"Any vehicle capable of exceeding 40 km/h on flat must have a speed indicator visible to the driver."
  },
  {
    id:9, category:'speed',
    q:"Motor vehicles (except mopeds) must have a sound alarm audible at least:",
    opts:["200m","150m","100m","50m"],
    correct:2,
    explain:"Standard motor vehicles: alarm audible at 100m. Mopeds: 20m. Slow vehicles (≤50km/h flat): 50m."
  },
  {
    id:10, category:'speed',
    q:"When unloaded vehicle speed on flat cannot exceed 50 km/h, the horn must be audible at:",
    opts:["100m","200m","50m","150m"],
    correct:2,
    explain:"Slow vehicles limited to 50 km/h on flat: horn must be audible at 50m."
  },
  {
    id:11, category:'speed',
    q:"Mopeds must have a horn audible at a distance of:",
    opts:["100m","50m","20m","200m"],
    correct:2,
    explain:"Mopeds (cyclomoteurs) require a horn audible at a minimum of 20m."
  },
  {
    id:12, category:'speed',
    q:"Emergency chain/cable towing fastening must be used at a maximum speed of:",
    opts:["50 km/h","30 km/h","20 km/h","10 km/h"],
    correct:2,
    explain:"Chain/cable fastening (force majeure towing) may only be used at max 20 km/h to reach the repair place."
  },
  {
    id:13, category:'vehicle',
    q:"Which vehicles must be inspected for roadworthiness every 6 months?",
    opts:["Only driving school vehicles","Only goods vehicles >3.5t","Public transport, goods >3.5t, and driving school vehicles","All private vehicles"],
    correct:2,
    explain:"All three: public transport, goods vehicles >3.5t, and driving school vehicles require 6-monthly inspections."
  },
  {
    id:14, category:'vehicle',
    q:"The device used for slowing down a vehicle in case of brake failure is called:",
    opts:["Service brake","Parking brake","Emergency brake","Drum brake"],
    correct:2,
    explain:"Service brake = normal driving | Parking brake = holds on slopes | Emergency brake = backup when service brake fails."
  },
  {
    id:15, category:'vehicle',
    q:"Which brake allows slowing and stopping quickly in any condition of loading, on any gradient?",
    opts:["Service brake","Emergency brake","Parking brake","Hydraulic brake"],
    correct:0,
    explain:"The service brake is the primary working brake — efficient stop regardless of load or road gradient."
  },
  {
    id:16, category:'vehicle',
    q:"Which brake maintains the vehicle immobile on a 16% slope using purely mechanical action, even without a driver?",
    opts:["Service brake","Emergency brake","Parking brake","All brakes"],
    correct:2,
    explain:"The parking brake uses purely mechanical action to hold the vehicle on a 16% slope without the driver present."
  },
  {
    id:17, category:'vehicle',
    q:"What is the minimum number of windscreen wipers required for every vehicle?",
    opts:["2","3","1","4"],
    correct:2,
    explain:"The legal minimum is 1 windscreen wiper. Most vehicles have 2, but 1 is the required minimum."
  },
  {
    id:18, category:'vehicle',
    q:"Children under what age are forbidden from the front seat when no other seats are available?",
    opts:["10 years","12 years","7 years","8 years"],
    correct:1,
    explain:"Children under 12 are forbidden from the front seat even when no other seats are available."
  },
  {
    id:19, category:'vehicle',
    q:"A speed limit plate is placed only on vehicles whose authorized weight exceeds:",
    opts:["1 tonne","2 tonnes","10 tonnes","24 tonnes"],
    correct:3,
    explain:"Speed limit marking plates are only required on very heavy vehicles exceeding 24 tonnes authorized weight."
  },
  {
    id:20, category:'vehicle',
    q:"Every fact requiring change to vehicle registration/owner details must be notified to the tax department within:",
    opts:["2 months","1 month","15 days","30 days"],
    correct:2,
    explain:"Changes must be reported within 15 days, either verbally or by registered letter."
  },
  {
    id:21, category:'vehicle',
    q:"Vehicles with width exceeding what measurement must be provided with loading/gauge lights?",
    opts:["3m","2.50m","2.10m","2m"],
    correct:2,
    explain:"Gauge/loading lights are required when vehicle width exceeds 2.10m."
  },
  {
    id:22, category:'vehicle',
    q:"The maximum rear overhang (loading) for bicycles, mopeds, and motorcycles is:",
    opts:["20cm","30cm","50cm","60cm"],
    correct:2,
    explain:"Loading on bicycles/mopeds/motorcycles cannot project more than 50cm beyond the rear edge."
  },
  {
    id:23, category:'vehicle',
    q:"Maximum length for vehicles with one axle is:",
    opts:["7m","9m","11m","14m"],
    correct:2,
    explain:"Single-axle vehicles are limited to 11m in length."
  },
  {
    id:24, category:'vehicle',
    q:"Maximum length for vehicles with two oscillating (side-by-side) axles is:",
    opts:["11m","10m","7m","9m"],
    correct:2,
    explain:"Vehicles with two oscillating axles are limited to 7m."
  },
  {
    id:25, category:'lights',
    q:"The red brake light must be visible in clear weather at a minimum distance of:",
    opts:["100m day / 20m night","150m day / 50m night","200m day / 100m night","50m day / 20m night"],
    correct:2,
    explain:"The brake light must be visible at 200m by day and 100m at night in clear weather."
  },
  {
    id:26, category:'lights',
    q:"Headlights (road lights) must be switched off when:",
    opts:["Only in agglomeration","Only when crossing another vehicle","When road lighting allows 20m visibility, when crossing, or in agglomeration (all three)","Only at night"],
    correct:2,
    explain:"All three: (1) continuous road lighting allows 20m visibility, (2) when crossing another vehicle, (3) in agglomeration."
  },
  {
    id:27, category:'lights',
    q:"Headlights must also be switched off when following another vehicle closer than:",
    opts:["50m","100m","150m","200m"],
    correct:1,
    explain:"When following within 100m, switch off bright headlights — unless signaling intent to overtake by flashing."
  },
  {
    id:28, category:'lights',
    q:"Reflectors placed on the SIDES of a vehicle are what color?",
    opts:["White","Yellow","Red","Orange"],
    correct:1,
    explain:"Side reflectors on vehicles must be yellow."
  },
  {
    id:29, category:'lights',
    q:"Road border reflectors: what color do road users see on their RIGHT side?",
    opts:["White","Yellow","Red or orange","Green"],
    correct:2,
    explain:"Right side = red or orange reflectors. Left side = white reflectors."
  },
  {
    id:30, category:'lights',
    q:"Road border reflectors: what color do road users see on their LEFT side?",
    opts:["White","Yellow","Red","Orange"],
    correct:0,
    explain:"Left side = white reflectors. Right side = red or orange reflectors."
  },
